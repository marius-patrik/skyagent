{
  "name": "skyagent",
  "version": "2.0.0",
  "description": "Provider-neutral Hypixel SkyBlock analysis and progression application for Agent OS.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marius-patrik/skyagent.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "bun run typecheck && bun run test && bun run validate:product && bun run validate:skill",
    "ci": "bun run check",
    "start": "bun ./packages/cli/src/bin.ts",
    "mcp": "bun ./packages/mcp/src/index.ts",
    "build:web": "bun run --cwd packages/web build",
    "dev:web": "bun run --cwd packages/web dev",
    "visual:web": "bun run --cwd packages/web visual:qa",
    "tui": "bun ./packages/tui/src/bin.ts",
    "test": "bun run build:web && bun test",
    "typecheck": "tsc --noEmit",
    "smoke": "bun ./packages/cli/src/bin.ts version --json && bun ./packages/cli/src/bin.ts doctor --json && bun ./packages/cli/src/bin.ts tui --smoke",
    "validate:product": "bun ./scripts/ci/validate-product.ts",
    "validate:skill": "bun ./scripts/ci/validate-skill.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@skyagent/cli": "workspace:*",
    "@skyagent/core": "workspace:*",
    "@skyagent/mcp": "workspace:*",
    "@skyagent/tui": "workspace:*",
    "@skyagent/web": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "26.0.1",
    "typescript": "5.9.3",
    "yaml": "2.9.0"
  }
}
