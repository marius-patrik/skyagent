{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@skyagent/cli": [
        "packages/cli/src/index.ts"
      ],
      "@skyagent/core": [
        "packages/core/src/index.ts"
      ],
      "@skyagent/core/*": [
        "packages/core/src/*.ts",
        "packages/core/src/*/index.ts"
      ],
      "@skyagent/mcp": [
        "packages/mcp/src/index.ts"
      ],
      "@skyagent/tui": [
        "packages/tui/src/index.tsx"
      ],
      "@skyagent/web": [
        "packages/web/src/main.tsx"
      ],
      "prismarine-nbt": [
        "node_modules/prismarine-nbt/nbt.js"
      ]
    },
    "jsx": "react-jsx",
    "types": [
      "bun",
      "node"
    ]
  },
  "include": [
    "scripts/**/*.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx"
  ]
}
